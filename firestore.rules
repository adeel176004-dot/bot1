rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Phase 3: Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Keeping it simple for demo
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string && data.email.size() <= 200
          && data.plan in ['free', 'basic', 'pro', 'professional', 'premium', 'enterprise']
          && data.totalMessages is number;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().totalMessages == 0;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'plan', 'totalMessages', 'updatedAt'])
      );
    }

    // --- Agents Collection ---
    match /agents/{agentId} {
      function isValidAgent(data) {
        return data.userId is string && data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 100
          && data.config is map;
      }

      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAgent(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidAgent(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'config', 'stats', 'updatedAt'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Conversations Collection ---
    match /conversations/{convId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
